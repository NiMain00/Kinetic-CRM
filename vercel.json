{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "static",
      "buildCommand": "npm run build",
      "outputDirectory": "dist"
    },
    "backend": {
      "root": "backend",
      "framework": "nestjs",
      "entrypoint": "src/main.ts"
    }
  },
  "rewrites": [ { "source": "/(.*)", "destination": "/index.html"
    },
    {
      "source": "/(.*)",
      "destination": {
        "type": "service",
        "service": "frontend"
      }
    }
  ]
}