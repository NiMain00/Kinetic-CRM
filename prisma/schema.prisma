  projectId      String          @unique @map("project_id")
  result         TenderResultEnum
  contractValue  Decimal?          @map("contract_value")
  lossReasonId   String?         @map("loss_reason_id")
  lossReasonNote String?         @map("loss_reason_note")
  spkDocument    String?         @map("spk_document")
  startDate      DateTime?       @map("start_date")
  durationDays   Int?            @map("duration_days")
  decidedAt      DateTime        @default(now()) @map("decided_at")
  decidedBy      String          @map("decided_by")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  lossReason LossReason? @relation(fields: [lossReasonId], references: [id])
  decider   User       @relation(fields: [decidedBy], references: [id])

  @@map("tender_results")
}

model DeliveryTarget {
  id              String         @id @default(uuid()) @map("id")
  projectId       String         @unique @map("project_id")
  startDate       DateTime?      @map("start_date")
  endDate         DateTime?      @map("end_date")
  actualEndDate   DateTime?      @map("actual_end_date")
  note            String?       
  isCompleted     Boolean        @default(false) @map("is_completed")
  completedAt     DateTime?      @map("completed_at")
  completedBy     String?        @map("completed_by")
  status          DeliveryStatus @default(scheduled)
  picName         String?        @map("pic_name")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("delivery_targets")
}

// ── APPROVAL & WORKFLOW ENGINE ───────────────────────────────────────────────

model SlaConfiguration {
  id                  String   @id @default(uuid()) @map("id")
  stageId             String   @unique @map("stage_id")
  name                String  
  entityType          String   @map("entity_type")
  warningThreshold    Int      @map("warning_threshold")
  criticalThreshold   Int      @map("critical_threshold")
  unit                String  
  escalationRole      String   @map("escalation_role")
  slaWorkingDays      Int?     @map("sla_working_days")
  isEnforcementActive Boolean  @default(true) @map("is_enforcement_active")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  stage    WorkflowStage               @relation(fields: [stageId], references: [id])
  reminders SlaReminderConfiguration[]

  @@map("sla_configurations")
}

model SlaReminderConfiguration {
  id                    String   @id @default(uuid()) @map("id")
  slaConfigurationId    String   @map("sla_configuration_id")
  reminderDaysBefore    Int      @map("reminder_days_before")
  escalationRoleId      String?  @map("escalation_role_id")
  userId                String?  @map("user_id")
  createdAt             DateTime @default(now()) @map("created_at")

  slaConfig       SlaConfiguration @relation(fields: [slaConfigurationId], references: [id], onDelete: Cascade)
  escalationRole  Role?           @relation(fields: [escalationRoleId], references: [id])
  user            User?           @relation("UserSlaReminders", fields: [userId], references: [id])

  @@map("sla_reminder_configurations")
}

model Approval {
  id                      String               @id @default(uuid()) @map("id")
  resourceType            ApprovalResourceType  @map("resource_type")
  resourceId              String               @map("resource_id")
  stageId                 String?              @map("stage_id")
  assignedToUserId        String?              @map("assigned_to_user_id")
  assignedToRoleId        String?              @map("assigned_to_role_id")
  assignedToDepartmentId  String?              @map("assigned_to_department_id")
  status                  ApprovalStatus       @default(pending)
  decisionComment         String?              @map("decision_comment")
  decidedBy               String?              @map("decided_by")
  decidedAt               DateTime?            @map("decided_at")
  slaDeadline             DateTime?            @map("sla_deadline")
  createdAt               DateTime             @default(now()) @map("created_at")
  updatedAt               DateTime             @updatedAt @map("updated_at")

  stage           WorkflowStage? @relation(fields: [stageId], references: [id])
  assigneeUser    User?          @relation("ApprovalAssignee", fields: [assignedToUserId], references: [id])
  assigneeRole    Role?          @relation("RoleApprovals", fields: [assignedToRoleId], references: [id])
  assigneeDept    OrgUnit?       @relation("DepartmentApprovals", fields: [assignedToDepartmentId], references: [id])
  decider         User?          @relation("ApprovalDecider", fields: [decidedBy], references: [id])
  reassignments   ApprovalReassignment[]

  @@index([resourceType, resourceId])
  @@map("approvals")
}

model ApprovalReassignment {
  id                        String   @id @default(uuid()) @map("id")
  approvalId                String   @map("approval_id")
  previousAssigneeUserId    String?  @map("previous_assignee_user_id")
  newAssigneeUserId         String   @map("new_assignee_user_id")
  reason                    String  
  reassignedBy              String   @map("reassigned_by")
  reassignedAt              DateTime @default(now()) @map("reassigned_at")

  approval         Approval @relation(fields: [approvalId], references: [id], onDelete: Cascade)
  previousAssignee User?    @relation("ApprovalReassignPrevious", fields: [previousAssigneeUserId], references: [id])
  newAssignee      User     @relation("ApprovalReassignNew", fields: [newAssigneeUserId], references: [id])
  reassignedByUser User     @relation("ApprovalReassignBy", fields: [reassignedBy], references: [id])

  @@map("approval_reassignments")
}

model ApprovalChain {
  id        String   @id @default(uuid()) @map("id")
  name      String  
  module    String  
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  levels    ApprovalChainLevel[]
  requests  ApprovalRequest[]

  @@map("approval_chains")
}

model ApprovalChainLevel {
  id            String   @id @default(uuid()) @map("id")
  chainId       String   @map("chain_id")
  name          String  
  role          String  
  order         Int      @map("order_level")
  minAmount     Decimal?   @map("min_amount")
  maxAmount     Decimal?   @map("max_amount")
  createdAt     DateTime @default(now()) @map("created_at")

  chain ApprovalChain @relation(fields: [chainId], references: [id], onDelete: Cascade)

  @@map("approval_chain_levels")
}

model ApprovalRequest {
  id            String   @id @default(uuid()) @map("id")
  chainId       String   @map("chain_id")
  entityId      String   @map("entity_id")
  entityType    String   @map("entity_type")
  entityName    String   @map("entity_name")
  entityCode    String   @map("entity_code")
  amount        Decimal    @default(0)
  currentLevel  Int      @default(0) @map("current_level")
  status        ApprovalStatus @default(pending)
  createdBy     String   @map("created_by")
  note          String? 
  createdAt     DateTime @default(now()) @map("created_at")
  resolvedAt    DateTime? @map("resolved_at")

  chain   ApprovalChain          @relation(fields: [chainId], references: [id])
  creator User                   @relation("ApprovalRequestsCreated", fields: [createdBy], references: [id])
  levels  ApprovalRequestLevel[]

  @@map("approval_requests")
}

model ApprovalRequestLevel {
  id          String        @id @default(uuid()) @map("id")
  requestId   String        @map("request_id")
  levelId     String        @map("level_id")
  levelName   String        @map("level_name")
