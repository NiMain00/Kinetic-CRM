  quantityRequired    Int                  @default(0) @map("quantity_required")
  quantityUsed        Int                  @default(0) @map("quantity_used")
  quantityProcured    Int                  @default(0) @map("quantity_procured")
  sourceDealLineId    String?              @map("source_deal_line_id")
  procurementStatus   ProcurementStatusEnum @default(none) @map("procurement_status")
  basePrice           Decimal                @default(0) @map("base_price") @db.Decimal(18, 2)
  discountPercent     Decimal                @default(0) @map("discount_percent") @db.Decimal(5, 2)
  discountAmount      Decimal                @default(0) @map("discount_amount") @db.Decimal(18, 2)
  taxPercent          Decimal                @default(0) @map("tax_percent") @db.Decimal(5, 2)
  totalPrice          Decimal                @default(0) @map("total_price") @db.Decimal(18, 2)
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  masterItem MasterItem @relation(fields: [masterItemId], references: [id])
  allocations ProcurementAllocation[]

  @@index([projectId])
  @@map("project_requirement_items")
}

model ProcurementItem {
  id                  String               @id @default(uuid()) @map("id")
  procurementId       String               @map("procurement_id")
  masterItemId        String               @map("master_item_id")
  quantity            Int                  @default(0)
  quantityReceived    Int                  @default(0) @map("quantity_received")
  unitPrice           Decimal                @default(0) @map("unit_price") @db.Decimal(18, 2)
  totalPrice          Decimal                @default(0) @map("total_price") @db.Decimal(18, 2)
  status              ProcurementItemStatus @default(pending)
  notes               String?              @db.Text
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")

  procurement  Procurement              @relation(fields: [procurementId], references: [id], onDelete: Cascade)
  masterItem   MasterItem               @relation(fields: [masterItemId], references: [id])
  allocations  ProcurementAllocation[]

  @@index([procurementId])
  @@map("procurement_items")
}

model ProcurementAllocation {
  id                    String   @id @default(uuid()) @map("id")
  procurementItemId     String   @map("procurement_item_id")
  projectId             String   @map("project_id")
  projectRequirementId  String   @map("project_requirement_id")
  quantity              Int      @default(0)
  createdAt             DateTime @default(now()) @map("created_at")

  procurementItem    ProcurementItem        @relation(fields: [procurementItemId], references: [id], onDelete: Cascade)
  requirement        ProjectRequirementItem @relation(fields: [projectRequirementId], references: [id])

  @@unique([procurementItemId, projectRequirementId])
  @@map("procurement_allocations")
}

// ── TASK MANAGEMENT ──────────────────────────────────────────────────────────

model Task {
  id          String     @id @default(uuid()) @map("id")
  projectId   String     @map("project_id")
  title       String     @db.VarChar(255)
  description String?    @db.Text
  assignee    String?    @db.VarChar(255)
  priority    TaskPriority @default(medium)
  status      TaskStatus @default(todo)
  dueDate     DateTime?  @map("due_date") @db.Date
  parentId    String?    @map("parent_id")
  order       Int        @default(0) @map("task_order")
  createdBy   String     @map("created_by")
  completedBy String?    @map("completed_by")
  completedAt DateTime?  @map("completed_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  project      Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  creator      User    @relation("TasksCreated", fields: [createdBy], references: [id])
  completer    User?   @relation("TasksCompleted", fields: [completedBy], references: [id])
  parent       Task?   @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks     Task[]  @relation("TaskSubtasks")

  @@index([projectId, status])
  @@map("tasks")
}

// ── CHAT ─────────────────────────────────────────────────────────────────────

model ChatMessage {
  id          String          @id @default(uuid()) @map("id")
  projectId   String          @map("project_id")
  senderId    String          @map("sender_id")
  senderName  String          @map("sender_name") @db.VarChar(255)
  senderRole  String?         @map("sender_role") @db.VarChar(100)
  content     String          @db.Text
  messageType ChatMessageType @default(text) @map("message_type")
  fileUrl     String?         @map("file_url") @db.Text
  fileName    String?         @map("file_name") @db.VarChar(255)
  fileSize    Int?            @map("file_size")
  mentions    String?         @db.Text
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id])
  readReceipts ChatMessageReadReceipt[]

  @@index([projectId, createdAt])
  @@map("chat_messages")
}

model ChatMessageReadReceipt {
  id        String   @id @default(uuid()) @map("id")
  messageId String   @map("message_id")
  userId    String   @map("user_id")
  readAt    DateTime @default(now()) @map("read_at")

  message ChatMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User        @relation("ChatMessageReadReceiptUser", fields: [userId], references: [id])

  @@unique([messageId, userId])
  @@map("chat_message_read_receipts")
}

// ── RELATION TRACKING ────────────────────────────────────────────────────────

model EntityRelation {
  id              String   @id @default(uuid()) @map("id")
  sourceType      String   @map("source_type") @db.VarChar(50)
  sourceId        String   @map("source_id")
  targetType      String   @map("target_type") @db.VarChar(50)
  targetId        String   @map("target_id")
  relationType    String   @map("relation_type") @db.VarChar(50)
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([sourceType, sourceId, targetType, targetId, relationType])
  @@index([sourceType, sourceId])
  @@index([targetType, targetId])
  @@map("entity_relations")
}
