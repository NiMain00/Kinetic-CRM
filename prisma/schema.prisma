// ─────────────────────────────────────────────────────────────────────────────
// KINETIC CRM — Prisma Schema (PostgreSQL)
// Dibuat dari analisis frontend (Prioritas 1) + dokumentasi (Prioritas 2)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url               = env("DATABASE_URL")
}

// ── ENUMS ────────────────────────────────────────────────────────────────────

enum OrgUnitType {
  company
  division
  branch
  department
}

enum CustomerType {
  swasta
  bumn
  pemerintah
  asing
}

enum CustomerLevel {
  hot    @map("hot")
  medium @map("medium")
  low    @map("low")
}

enum ProspectStatus {
  Lead               @map("lead")
  Non_Potensial      @map("non_potensial")
  Potensial          @map("potensial")
  Waiting_Supervisor @map("waiting_supervisor")
  Revision           @map("revision")
  Approved           @map("approved")
}

enum ProspectCustomerType {
  existing
  new
}

enum RksStatus {
  draft
  waiting_pm_approval @map("waiting_pm_approval")
  revision
  approved
}

enum LphsStatus {
  draft
  lphs_sios    @map("lphs_sios")
  approved
}

enum LphsApprovalStatus {
  reviewing
  pending_pm       @map("pending_pm")
  approved
  revision_requested @map("revision_requested")
}

enum TenderResultEnum {
  won
  lost
}

enum DeliveryStatus {
  scheduled
  in_progress   @map("in_progress")
  completed
  delayed
}

enum ApprovalResourceType {
  prospect
  rks
  lphs_sios    @map("lphs_sios")
}

enum ApprovalStatus {
  pending
  in_progress  @map("in_progress")
  approved
  rejected
  superseded
}

enum ApprovalScopeType {
  global
  department
  project
}

enum AccessLevel {
  read
  write
}

enum NotificationType {
  approval
  revision
  status_change    @map("status_change")
  assignment
  system
}

enum NotificationChannel {
  in_app   @map("in_app")
  email
}

enum AuditResult {
  success
  denied
  error
}

enum AiRequestStatus {
  success
  failed
  rate_limited   @map("rate_limited")
}

enum TaskPriority {
  low
  medium
  high
}

enum TaskStatus {
  todo
  in_progress  @map("in_progress")
  review
  done
}

enum ProcurementStatus {
  Draft         @map("draft")
  Purchase_Request    @map("purchase_request")
  Vendor_Selection    @map("vendor_selection")
  PO_Process          @map("po_process")
  Delivery
  Progress
  Closed
  Cancelled
}

enum SupplierStatus {
  active
  inactive
  blacklisted
}

enum SupplierType {
  manufacturer
  distributor
  agent
  contractor
  consultant
}

enum RfqStatus {
  draft
  sent
  evaluating
  completed
  cancelled
}

enum RfqQuoteStatus {
  pending
  evaluated
  selected
  rejected
}

enum ProcurementItemStatus {
  pending
  ordered
  partial
  received
  cancelled
}

enum ProcurementStatusEnum {
  none
  partial
  fully_submitted @map("fully_submitted")
  received
}

enum MasterItemType {
  barang
  jasa
}

enum QuestionContext {
  prospect
  rks
  both
}

enum QuestionTypeCode {
  text
  textarea
  radio
  checkbox
  select
  number
  date
}

enum PeriodType {
  monthly
  quarterly
  semester
  annual
}

enum KpiUnit {
  currency
  percentage
  count
}

enum TrafficLight {
  red
  yellow
  green
}

enum ScopeType {
  branch
  division
  company
}

enum ConnectorType {
  API
  Webhook
  Email
  Database
  Cloud_Storage  @map("cloud_storage")
  LDAP
}

enum ConnectorStatus {
  connected
  disconnected
  error
}

enum InputConfigCategory {
  form
  filter
  sla
  workflow
  other
}

enum LossReasonCategory {
  harga
  teknis
  administrasi
  lainnya
}

enum HolidayType {
  national
  regional
}

enum DocumentResourceType {
  prospect
  rks
  lphs_sios   @map("lphs_sios")
  harga
  pemenang
  project_misc @map("project_misc")
}

enum ChatMessageType {
  text
  file
  image
}

enum VisitStatus {
  pending   @map("pending")
  completed @map("completed")
  cancelled @map("cancelled")
}

enum FollowUpStatus {
  pending       @map("pending")
  in_progress   @map("in_progress")
  completed     @map("completed")
}

enum UserStatus {
  active
  inactive
}

// ── MODELS ───────────────────────────────────────────────────────────────────

// ── ORGANIZATION & ACCESS ────────────────────────────────────────────────────

model OrgUnit {
  id         String      @id @default(uuid()) @map("id")
  name       String     
  code       String      @unique
  parentId   String?     @map("parent_id")
  unitType   OrgUnitType @map("unit_type")
  city       String?    
  province   String?    
  address    String?  
  description String?   @map("description")
  phone      String?  
  isActive   Boolean     @default(true) @map("is_active")
  sortOrder  Int         @default(0) @map("sort_order")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  deletedAt  DateTime?   @map("deleted_at")

  parent     OrgUnit?    @relation("OrgUnitHierarchy", fields: [parentId], references: [id])
  children   OrgUnit[]   @relation("OrgUnitHierarchy")

  users         User[]
  prospects     Prospect[]        @relation("BranchProspects")
  projects      Project[]         @relation("BranchProjects")
  lphsDeptRevs  LphsDepartmentReview[]
  lphsTargetRev LphsTargetedRevisionDepartment[]
  approvals     Approval[]        @relation("DepartmentApprovals")
  documents     Document[]
  notificationRecipients NotificationTemplateRecipient[]

  @@map("org_units")
}

model User {
  id            String      @id @default(uuid()) @map("id")
  username      String      @unique
  fullName      String      @map("full_name")
  email         String      @unique
  passwordHash  String      @map("password_hash")
  phone         String?    
  avatarUrl     String?     @map("avatar_url")
  status        UserStatus  @default(active)
  isLocked      Boolean     @default(false) @map("is_locked")
  failedLoginCount Int      @default(0) @map("failed_login_count")
  lastLoginAt   DateTime?   @map("last_login_at")
  orgUnitId     String?     @map("org_unit_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  orgUnit       OrgUnit?         @relation(fields: [orgUnitId], references: [id])

  sessions          ActiveSession[]
  userRoles         UserRole[]
  createdProspects  Prospect[]       @relation("CreatedProspects")
  ownedProspects    Prospect[]       @relation("OwnedProspects")
  createdProjects   Project[]        @relation("CreatedProjects")
  ownedProjects     Project[]        @relation("OwnedProjects")
  projectMembers    ProjectMember[]
  timelineEvents    ProjectTimelineEvent[]
  rksReviewQs       RksReviewQuestion[]
  rksReviewNs       RksReviewNote[]
  prospectReviewQuestions ProspectReviewQuestion[] @relation("ProspectReviewQuestionCreator")
  prospectReviewNotes     ProspectReviewNote[]     @relation("ProspectReviewNoteCreator")
  lphsReviewedBy    LphsDepartmentReview[]    @relation("LphsReviewedBy")
  lphsPmApprovedBy  LphsSios[]                @relation("LphsPmApproved")
  lphsMgmtApprovedBy LphsSios[]               @relation("LphsMgmtApproved")
  lphsFinalApproved LphsSios[]                @relation("LphsFinalApproved")
  lphsTargetedRevisions LphsTargetedRevision[]
  priceSubmissions  PriceSubmission[]
  tenderResults     TenderResult[]
  approvals         Approval[]                 @relation("ApprovalAssignee")
  approvalDecisions Approval[]                 @relation("ApprovalDecider")
  approvalReassignPrevious    ApprovalReassignment[] @relation("ApprovalReassignPrevious")
  approvalReassignNew         ApprovalReassignment[] @relation("ApprovalReassignNew")
  approvalReassignBy          ApprovalReassignment[] @relation("ApprovalReassignBy")
  backupApproverDelegations_primary  BackupApproverDelegation[] @relation("BackupPrimary")
  backupApproverDelegations_backup   BackupApproverDelegation[] @relation("BackupSecondary")
  backupApproverDelegations_created  BackupApproverDelegation[] @relation("BackupCreator")
  documentsUploaded  Document[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  aiRequestLogs      AiRequestLog[]
  tasksCreated       Task[]          @relation("TasksCreated")
  tasksCompleted     Task[]          @relation("TasksCompleted")
  chats              ChatMessage[]
  readReceipts       ChatMessageReadReceipt[] @relation("ChatMessageReadReceiptUser")
  kpiWeights         KpiWeight[]
  targets            Target[]
  integrationConfigs IntegrationConfiguration[]
  slaReminders       SlaReminderConfiguration[] @relation("UserSlaReminders")
  approvalRequests   ApprovalRequest[]    @relation("ApprovalRequestsCreated")
  procurementCreated Procurement[]        @relation("ProcurementCreated")
  procurementDelivered Procurement[]      @relation("ProcurementDelivered")
  procurementClosed   Procurement[]      @relation("ProcurementClosed")
  rfqs               Rfq[]
  suppliers          Supplier[]
  supplierEvals      SupplierEvaluation[] @relation("UserSupplierEvals")
  visits             Visit[]             @relation("VisitPicUser")
  followUpTasksFrom  FollowUpTask[]      @relation("FollowUpFromUser")
  followUpTasksTo    FollowUpTask[]      @relation("FollowUpToUser")

  @@map("users")
}

model ActiveSession {
  id        String    @id @default(uuid()) @map("id")
  userId    String    @map("user_id")
  tokenJti  String    @unique @map("token_jti")
  ipAddress String    @map("ip_address")
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("active_sessions")
}

model Role {
  id            String   @id @default(uuid()) @map("id")
  name          String  
  description   String? 
  isSystem      Boolean  @default(false) @map("is_system")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userRoles        UserRole[]
  workflowStages   WorkflowStage[] @relation("RoleWorkflowStages")
  approvals        Approval[]     @relation("RoleApprovals")
  slaReminders     SlaReminderConfiguration[]
  notificationRecipients NotificationTemplateRecipient[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @map("id")
  code        String   @unique
  name        String  
  module      String  
  description String? 
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id          String       @id @default(uuid()) @map("id")
  roleId      String       @map("role_id")
  permissionId String      @map("permission_id")
  scopeType   ApprovalScopeType? @map("scope_type")
  scopeId     String?      @map("scope_id")
  stageId     String?      @map("stage_id")
  accessLevel AccessLevel  @default(write) @map("access_level")
  createdAt   DateTime     @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId, scopeType, scopeId])
  @@map("role_permissions")
}

model UserRole {
  id        String           @id @default(uuid()) @map("id")
  userId    String           @map("user_id")
  roleId    String           @map("role_id")
  scopeType ApprovalScopeType @map("scope_type")
  scopeId   String?          @map("scope_id")
  assignedBy String?         @map("assigned_by")
  expiresAt DateTime?        @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("user_roles")
}

model WorkflowStage {
  id                  String   @id @default(uuid()) @map("id")
  code                String   @unique
  name                String  
  module              String  
  sequence            Float    @map("sequence")
  ownerDepartmentCode String   @map("owner_department_code")
  prevDepartmentCode  String?  @map("prev_department_code")
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  slaConfig SlaConfiguration?
  approvals Approval[]
  roleId    String?   @map("role_id")
  role      Role?     @relation("RoleWorkflowStages", fields: [roleId], references: [id])

  stageDepartments WorkflowStageDepartment[]

  @@map("workflow_stages")
}

model WorkflowStageDepartment {
  id             String      @id @default(uuid()) @map("id")
  stageId        String      @map("stage_id")
  departmentCode String      @map("department_code")
  accessLevel    AccessLevel @default(read) @map("access_level")
  createdAt      DateTime    @default(now()) @map("created_at")

  stage WorkflowStage @relation(fields: [stageId], references: [id], onDelete: Cascade)

  @@unique([stageId, departmentCode])
  @@map("workflow_stage_departments")
}

model ProjectMember {
  id           String   @id @default(uuid()) @map("id")
  projectId    String   @map("project_id")
  userId       String   @map("user_id")
  roleId       String   @map("role_id")
  departmentId String   @map("department_id")
  assignedBy   String   @map("assigned_by")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectDepartment {
  id           String   @id @default(uuid()) @map("id")
  projectId    String   @map("project_id")
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, departmentId])
  @@map("project_departments")
}

// ── MASTER DATA ──────────────────────────────────────────────────────────────

model Customer {
  id            String       @id @default(uuid()) @map("id")
  name          String       @unique
  code          String       @unique
  type          CustomerType
  city          String      
  npwp          String?     
  picName       String?      @map("pic_name")
  picPosition   String?      @map("pic_position")
  picPhone      String?      @map("pic_phone")
  picEmail      String?      @map("pic_email")
  address       String?     
  province      String?     
  industryId    String?      @map("industry_id")
  providerExisting String?   @map("provider_existing")
  isNew         Boolean?     @default(false) @map("is_new")
  needsVerification Boolean? @default(false) @map("needs_verification")
  verifiedAt    DateTime?    @map("verified_at")
  verifiedBy    String?      @map("verified_by")
  isActive      Boolean      @default(true) @map("is_active")
  parentId      String?      @map("parent_id")
  level         CustomerLevel?
  requirements  String?     
  unitLevel     String?      @map("unit_level")
  canonicalName String?      @map("canonical_name")
  source        String?     
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  parent     Customer?  @relation("CustomerHierarchy", fields: [parentId], references: [id])
  children   Customer[] @relation("CustomerHierarchy")

  prospects      Prospect[]
  projects       Project[]
  visits         Visit[]
  followUpTasks  FollowUpTask[]

  @@map("customers")
}

model Industry {
  id        String   @id @default(uuid()) @map("id")
  name      String  
  code      String   @unique
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("industries")
}

model ProjectCategory {
  id               String   @id @default(uuid()) @map("id")
  name             String   @unique
  code             String   @unique
  description      String? 
  requiresLphs     Boolean  @default(true) @map("requires_lphs")
  requiresRks      Boolean  @default(true) @map("requires_rks")
  defaultWorkflowType String @default("tender") @map("default_workflow_type")
  colorHex         String?  @map("color_hex")
  sortOrder        Int      @default(0) @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  prospects Prospect[]
  projects  Project[]

  @@map("project_categories")
}

model ProjectStatusDefinition {
  id          String   @id @default(uuid()) @map("id")
  code        String   @unique
  label       String  
  description String? 
  colorHex    String   @map("color_hex")
  textColorHex String  @map("text_color_hex")
  sortOrder   Int      @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system")
  isTerminal  Boolean  @default(false) @map("is_terminal")
  applicableTo String  @default("both") @map("applicable_to")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("project_status_definitions")
}

model Competitor {
  id            String      @id @default(uuid()) @map("id")
  name          String      @unique
  code          String?    
  minPrice      Decimal?      @map("min_price")
  maxPrice      Decimal?      @map("max_price")
  industryId    String?     @map("industry_id")
  bidangUsaha   String?     @map("bidang_usaha")
  website       String?    
  advantages    String?    
  description   String?    
  notes         String?    
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  projectCompetitors ProjectCompetitor[]

  @@map("competitors")
}

model QuestionType {
  id              String         @id @default(uuid()) @map("id")
  name            String        
  code            QuestionTypeCode @unique
  description     String?       
  hasOptions      Boolean        @default(false) @map("has_options")
  validationConfig String?       @map("validation_config")
  isSystem        Boolean        @default(false) @map("is_system")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  questions Question[]

  @@map("question_types")
}

model Question {
  id            String         @id @default(uuid()) @map("id")
  questionText  String         @map("question_text")
  questionTypeId String        @map("question_type_id")
  context       QuestionContext
  category      String?       
  isRequired    Boolean        @default(false) @map("is_required")
  sortOrder     Int            @default(0) @map("sort_order")
  placeholderText String?      @map("placeholder_text")
  helpText      String?        @map("help_text")
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  questionType         QuestionType       @relation(fields: [questionTypeId], references: [id])
  questionOptions      QuestionOption[]
  prospectAnswers      ProspectAnswer[]

  @@map("questions")
}

model QuestionOption {
  id          String   @id @default(uuid()) @map("id")
  questionId  String   @map("question_id")
  optionLabel String   @map("option_label")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  question            Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  prospectAnswers     ProspectAnswer[]      @relation("QuestionOptionAnswers")
  prospectAnswerOpts  ProspectAnswerOption[]

  @@map("question_options")
}

model Period {
  id        String     @id @default(uuid()) @map("id")
  name      String    
  code      String     @unique
  type      PeriodType
  year      Int
  startDate DateTime   @map("start_date")
  endDate   DateTime   @map("end_date")
  isActive  Boolean    @default(true) @map("is_active")
  isLocked  Boolean    @default(false) @map("is_locked")
  notes     String?   
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  targets Target[]

  @@map("periods")
}

model Holiday {
  id        String      @id @default(uuid()) @map("id")
  name      String     
  date      DateTime   
  type      HolidayType
  year      Int
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([date, type])
  @@map("holidays")
}

model LossReason {
  id          String            @id @default(uuid()) @map("id")
  name        String           
  code        String            @unique
  category    LossReasonCategory
  description String?          
  sortOrder   Int               @default(0) @map("sort_order")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenderResults TenderResult[]

  @@map("loss_reasons")
}

model DocumentType {
  id                String   @id @default(uuid()) @map("id")
  name              String  
  code              String   @unique
  description       String? 
  allowedExtensions String?  @map("allowed_extensions")
  maxSizeMb         Int?     @map("max_size_mb")
  isRequiredAtStage String?  @map("is_required_at_stage")
  applicableTo      String   @default("both") @map("applicable_to")
  sortOrder         Int      @default(0) @map("sort_order")
  isSystem          Boolean  @default(false) @map("is_system")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  documents Document[]
  uploadPolicies UploadPolicyConfiguration[]

  @@map("document_types")
}

// ── PROSPECT MANAGEMENT ──────────────────────────────────────────────────────

model Prospect {
  id                String          @id @default(uuid()) @map("id")
  name              String         
  client            String         
  customerId        String?         @map("customer_id")
  customerType      ProspectCustomerType? @map("customer_type")
  status            ProspectStatus  @default(Lead)
  prospectType      String?         @map("prospect_type")
  potensiUnit       Int             @default(0) @map("potensi_unit")
  estimatedValue    Decimal?          @map("estimated_value")
  description       String?        
  branch            String?        
  branchId          String?         @map("branch_id")
  categoryId        String?         @map("category_id")
  industryId        String?         @map("industry_id")
  providerExisting  String?         @map("provider_existing")
  projectType       String?         @map("project_type")
  isConverted       Boolean         @default(false) @map("is_converted")
  convertedToProjectId String?      @unique @map("converted_to_project_id")
  createdByUserId   String?         @map("created_by_user_id")
  departmentId      String?         @map("department_id")
  currentStageId    String?         @map("current_stage_id")
  ownerUserId       String?         @map("owner_user_id")
  source            String?        
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  customer          Customer?       @relation(fields: [customerId], references: [id])
  branchRel         OrgUnit?        @relation("BranchProspects", fields: [branchId], references: [id])
  category          ProjectCategory? @relation(fields: [categoryId], references: [id])
  createdBy         User?           @relation("CreatedProspects", fields: [createdByUserId], references: [id])
  ownerUser         User?           @relation("OwnedProspects", fields: [ownerUserId], references: [id])
  project           Project?        @relation("ProspectToProject", fields: [convertedToProjectId], references: [id])
  sourceProjects    Project[]       @relation("ProjectToProspect")

  answers            ProspectAnswer[]
  reviewQuestions    ProspectReviewQuestion[]
  reviewNotes        ProspectReviewNote[]
  timelineEvents     ProspectTimelineEvent[]
  visits             Visit[]
  followUpTasks      FollowUpTask[]

  @@map("prospects")
}

model ProspectAnswer {
  id              String   @id @default(uuid()) @map("id")
  prospectId      String   @map("prospect_id")
  questionId      String   @map("question_id")
  answerText      String?  @map("answer_text")
  answerOptionId  String?  @map("answer_option_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  prospect        Prospect          @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  question        Question          @relation(fields: [questionId], references: [id])
  answerOption    QuestionOption?   @relation("QuestionOptionAnswers", fields: [answerOptionId], references: [id])
  answerOptions   ProspectAnswerOption[]

  @@unique([prospectId, questionId])
  @@map("prospect_answers")
}

model ProspectAnswerOption {
  id                String   @id @default(uuid()) @map("id")
  prospectAnswerId  String   @map("prospect_answer_id")
  questionOptionId  String   @map("question_option_id")
  createdAt         DateTime @default(now()) @map("created_at")

  prospectAnswer ProspectAnswer @relation(fields: [prospectAnswerId], references: [id], onDelete: Cascade)
  questionOption QuestionOption @relation(fields: [questionOptionId], references: [id])

  @@unique([prospectAnswerId, questionOptionId])
  @@map("prospect_answer_options")
}

model ProspectReviewQuestion {
  id            String   @id @default(uuid()) @map("id")
  prospectId    String   @map("prospect_id")
  reviewRound   Int      @map("review_round")
  questionText  String   @map("question_text")
  answerText    String?  @map("answer_text")
  createdBy     String   @map("created_by")
  answeredAt    DateTime? @map("answered_at")
  createdAt     DateTime @default(now()) @map("created_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  creator  User     @relation("ProspectReviewQuestionCreator", fields: [createdBy], references: [id])

  @@map("prospect_review_questions")
}

model ProspectReviewNote {
  id          String   @id @default(uuid()) @map("id")
  prospectId  String   @map("prospect_id")
  reviewRound Int      @map("review_round")
  noteText    String   @map("note_text")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  creator  User     @relation("ProspectReviewNoteCreator", fields: [createdBy], references: [id])

  @@map("prospect_review_notes")
}

model ProspectTimelineEvent {
  id          String   @id @default(uuid()) @map("id")
  prospectId  String   @map("prospect_id")
  title       String  
  actor       String  
  role        String? 
  time        DateTime @default(now()) @map("time")
  type        String  
  description String? 
  prevVal     String?  @map("prev_val")
  newVal      String?  @map("new_val")
  createdAt   DateTime @default(now()) @map("created_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@map("prospect_timeline_events")
}

// ── VISIT (Kunjungan Prospek) ─────────────────────────────────────────────

model Visit {
  id          String      @id @default(uuid()) @map("id")
  prospectId  String      @map("prospect_id")
  customerId  String?     @map("customer_id")
  visitNumber Int         @map("visit_number")
  status      VisitStatus @default(pending)
  date        DateTime    @map("date")
  notes       String?    
  picName     String?     @map("pic_name")
  picUserId   String?     @map("pic_user_id")
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)
  customer Customer? @relation(fields: [customerId], references: [id])
  picUser  User?    @relation("VisitPicUser", fields: [picUserId], references: [id])

  @@unique([prospectId, visitNumber])
  @@index([prospectId])
  @@index([customerId])
  @@map("visits")
}

// ── FOLLOW-UP TASK (Tindak Lanjut Prospek) ────────────────────────────────

model FollowUpTask {
  id          String         @id @default(uuid()) @map("id")
  title       String        
  prospectId  String?        @map("prospect_id")
  customerId  String?        @map("customer_id")
  fromUserId  String         @map("from_user_id")
  toUserId    String         @map("to_user_id")
  status      FollowUpStatus @default(pending)
  priority    TaskPriority   @default(medium)
  progress    Int            @default(0)
  notes       String?       
  deadline    DateTime?      @map("deadline")
  completedAt DateTime?      @map("completed_at")
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  prospect Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  customer Customer? @relation(fields: [customerId], references: [id], onDelete: SetNull)
  fromUser User      @relation("FollowUpFromUser", fields: [fromUserId], references: [id])
  toUser   User      @relation("FollowUpToUser", fields: [toUserId], references: [id])

  @@index([prospectId])
  @@index([toUserId])
  @@index([status])
  @@map("follow_up_tasks")
}

// ── PROJECT CORE ─────────────────────────────────────────────────────────────

model Project {
  id               String   @id @default(uuid()) @map("id")
  code             String   @unique
  name             String  
  client           String  
  type             String  
  location         String  
  status           String  
  phase            String? 
  progress         Int      @default(0)
  estimatedValue   Decimal?   @map("estimated_value")
  deadlineTender   DateTime? @map("deadline_tender")
  sourceProspectId String?  @map("source_prospect_id")
  // DB-computed column: mirrors source_prospect_id while the project is active (NULL once
  // soft-deleted). Backs a unique index so a prospect maps to one ACTIVE project. Never read
  // or written by application code, hence @ignore.
  sourceProspectIdActive String? @ignore @map("source_prospect_id_active")
  customerId      String?  @map("customer_id")
  providerExisting String?  @map("provider_existing")
  branch           String? 
  branchId         String?  @map("branch_id")
  departmentId     String?  @map("department_id")
  categoryId       String?  @map("category_id")
  statusId         String?  @map("status_id")
  currentStageId   String?  @map("current_stage_id")
  createdByUserId  String?  @map("created_by_user_id")
  ownerUserId      String?  @map("owner_user_id")
  scopeDepartments String?  @map("scope_departments")
  author           String? 
  date             DateTime @default(now()) @map("date")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")

  prospect      Prospect?                @relation("ProjectToProspect", fields: [sourceProspectId], references: [id])
  convertedProspect Prospect?            @relation("ProspectToProject")
  customer      Customer?                @relation(fields: [customerId], references: [id])
  branchRel     OrgUnit?                 @relation("BranchProjects", fields: [branchId], references: [id])
  category      ProjectCategory?         @relation(fields: [categoryId], references: [id])
  statusDef     ProjectStatusDefinition? @relation(fields: [statusId], references: [id])
  createdBy     User?                    @relation("CreatedProjects", fields: [createdByUserId], references: [id])
  ownerUser     User?                    @relation("OwnedProjects", fields: [ownerUserId], references: [id])

  members            ProjectMember[]
  departments        ProjectDepartment[]
  timelineEvents     ProjectTimelineEvent[]
  rks                Rks?
  lphsSios           LphsSios?
  priceSubmission    PriceSubmission?
  projectCompetitors ProjectCompetitor[]
  tenderResult       TenderResult?
  deliveryTarget     DeliveryTarget?
  tasks              Task[]
  procurements       Procurement[]
  requirements       ProjectRequirementItem[]
  chatMessages       ChatMessage[]

  @@index([status])
  @@index([type])
  @@index([createdByUserId])
  @@index([sourceProspectId])
  @@map("projects")
}

model ProjectTimelineEvent {
  id          String   @id @default(uuid()) @map("id")
  projectId   String   @map("project_id")
  title       String  
  actor       String  
  role        String? 
  time        DateTime @default(now()) @map("time")
  type        String  
  description String? 
  prevVal     String?  @map("prev_val")
  newVal      String?  @map("new_val")
  fileName    String?  @map("file_name")
  fileSize    String?  @map("file_size")
  createdAt   DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  actorUser User? @relation(fields: [actor], references: [id])

  @@map("project_timeline_events")
}

// ── RKS MODULE ───────────────────────────────────────────────────────────────

model Rks {
  id              String   @id @default(uuid()) @map("id")
  projectId       String   @unique @map("project_id")
  nomorTender     String?  @map("nomor_tender")
  namaTender      String?  @map("nama_tender")
  deadlineTender  DateTime? @map("deadline_tender")
  aanwijzing      String? 
  workLocation    String?  @map("work_location")
  mainScope       String?  @map("main_scope")
  additionalNotes String?  @map("additional_notes")
  answers         Json?    @map("answers")
  status          RksStatus @default(draft)
