  pmApprovedByUser     User?                           @relation("LphsPmApproved", fields: [pmApprovedBy], references: [id])
  mgmtApprovedByUser   User?                           @relation("LphsMgmtApproved", fields: [mgmtApprovedBy], references: [id])
  finalApprovedByUser  User?                           @relation("LphsFinalApproved", fields: [finalApprovedBy], references: [id])
  departmentReviews    LphsDepartmentReview[]
  targetedRevisions    LphsTargetedRevision[]

  @@map("lphs_sios")
}

model LphsDepartmentReview {
  id              String             @id @default(uuid()) @map("id")
  lphsSiosId      String             @map("lphs_sios_id")
  departmentId    String             @map("department_id")
  approvalStatus  LphsApprovalStatus @default(reviewing) @map("approval_status")
  comment         String?           
  reviewedBy      String?            @map("reviewed_by")
  reviewedAt      DateTime?          @map("reviewed_at")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @updatedAt @map("updated_at")

  lphsSios   LphsSios @relation(fields: [lphsSiosId], references: [id], onDelete: Cascade)
  department OrgUnit  @relation(fields: [departmentId], references: [id])
  reviewer   User?    @relation("LphsReviewedBy", fields: [reviewedBy], references: [id])

