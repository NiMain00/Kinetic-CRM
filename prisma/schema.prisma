// ─────────────────────────────────────────────────────────────────────────────
// KINETIC CRM — Prisma Schema (MySQL 8)
// Dibuat dari analisis frontend (Prioritas 1) + dokumentasi (Prioritas 2)
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "multiSchema"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ── ENUMS ────────────────────────────────────────────────────────────────────

enum OrgUnitType {
  company
  division
  branch
  department
}

enum CustomerType {
  swasta
  bumn
  pemerintah
  asing
}

enum ProspectStatus {
  Non_Potensial      @map("non_potensial")
  Potensial          @map("potensial")
  Waiting_Supervisor @map("waiting_supervisor")
  Revision           @map("revision")
  Approved           @map("approved")
}

enum ProspectCustomerType {
  existing
  new
}

enum ProjectType {
  tender
  prospecting
}

enum RksStatus {
  draft
  waiting_pm_approval @map("waiting_pm_approval")
  revision
  approved
}

enum LphsStatus {
  draft
  lphs_sios    @map("lphs_sios")
  approved
}

enum LphsApprovalStatus {
  reviewing
  pending_pm       @map("pending_pm")
  approved
  revision_requested @map("revision_requested")
}

enum TenderResultEnum {
  won
  lost
}

enum DeliveryStatus {
  scheduled
  in_progress   @map("in_progress")
  completed
  delayed
}

enum ApprovalResourceType {
  prospect
  rks
  lphs_sios    @map("lphs_sios")
}

enum ApprovalStatus {
  pending
  in_progress  @map("in_progress")
  approved
  rejected
  superseded
}

enum ApprovalScopeType {
  global
  department
  project
}

enum AccessLevel {
  read
  write
}

enum NotificationType {
  approval
  revision
  status_change    @map("status_change")
  assignment
  system
}

enum NotificationChannel {
  in_app   @map("in_app")
  email
}

enum AuditResult {
  success
  denied
  error
}

enum AiRequestStatus {
  success
  failed
  rate_limited   @map("rate_limited")
}

enum TaskPriority {
  low
  medium
  high
  urgent
}

enum TaskStatus {
  todo
  in_progress  @map("in_progress")
  review
  done
}

enum ProcurementStatus {
  Draft         @map("draft")
  Purchase_Request    @map("purchase_request")
  Vendor_Selection    @map("vendor_selection")
  PO_Process          @map("po_process")
  Delivery
  Progress
  Closed
  Cancelled
}

enum SupplierStatus {
  active
  inactive
  blacklisted
}

enum SupplierType {
  manufacturer
  distributor
  agent
  contractor
  consultant
}

enum RfqStatus {
  draft
  sent
  evaluating
  completed
  cancelled
}

enum RfqQuoteStatus {
  pending
  evaluated
  selected
  rejected
}

enum ProcurementItemStatus {
  pending
  ordered
  partial
  received
  cancelled
}

enum ProcurementStatusEnum {
  none
  partial
  fully_submitted @map("fully_submitted")
  received
}

enum MasterItemType {
  barang
  jasa
}

enum QuestionContext {
  prospect
  rks
  both
}

enum QuestionTypeCode {
  text
  textarea
  radio
  checkbox
  select
  number
  date
}

enum PeriodType {
  monthly
  quarterly
  semester
  annual
}

enum KpiUnit {
  currency
  percentage
  count
}

enum TrafficLight {
  red
  yellow
  green
}

enum ScopeType {
  branch
  division
  company
}

enum ConnectorType {
  API
  Webhook
  Email
  Database
  Cloud_Storage  @map("cloud_storage")
  LDAP
}

enum ConnectorStatus {
  connected
  disconnected
  error
}

enum InputConfigCategory {
  form
  filter
  sla
  workflow
  other
}

enum LossReasonCategory {
  harga
  teknis
  administrasi
  lainnya
}

enum HolidayType {
  national
  regional
}

enum DocumentResourceType {
  prospect
  rks
  lphs_sios   @map("lphs_sios")
  harga
  pemenang
  project_misc @map("project_misc")
}

enum ChatMessageType {
  text
  file
  image
}

enum UserStatus {
  active
  inactive
}

// ── MODELS ───────────────────────────────────────────────────────────────────

// ── ORGANIZATION & ACCESS ────────────────────────────────────────────────────

model OrgUnit {
  id         String      @id @default(uuid()) @map("id")
  name       String      @db.VarChar(255)
  code       String      @unique @db.VarChar(50)
  parentId   String?     @map("parent_id")
  unitType   OrgUnitType @map("unit_type")
  city       String?     @db.VarChar(100)
  province   String?     @db.VarChar(100)
  address    String?     @db.Text
  phone      String?     @db.VarChar(50)
  isActive   Boolean     @default(true) @map("is_active")
  sortOrder  Int         @default(0) @map("sort_order")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  deletedAt  DateTime?   @map("deleted_at")

  parent     OrgUnit?    @relation("OrgUnitHierarchy", fields: [parentId], references: [id])
  children   OrgUnit[]   @relation("OrgUnitHierarchy")

  users         User[]
  prospects     Prospect[]        @relation("BranchProspects")
  projects      Project[]         @relation("BranchProjects")
  lphsDeptRevs  LphsDepartmentReview[]
  lphsTargetRev LphsTargetedRevisionDepartment[]
  approvals     Approval[]        @relation("DepartmentApprovals")
  documents     Document[]
  notificationRecipients NotificationTemplateRecipient[]

  @@map("org_units")
}

model User {
  id            String      @id @default(uuid()) @map("id")
  username      String      @unique @db.VarChar(50)
  fullName      String      @map("full_name") @db.VarChar(255)
  email         String      @unique @db.VarChar(255)
  passwordHash  String      @map("password_hash") @db.VarChar(255)
  phone         String?     @db.VarChar(50)
  avatarUrl     String?     @map("avatar_url") @db.Text
  status        UserStatus  @default(active)
  isLocked      Boolean     @default(false) @map("is_locked")
  failedLoginCount Int      @default(0) @map("failed_login_count")
  lastLoginAt   DateTime?   @map("last_login_at")
  orgUnitId     String?     @map("org_unit_id")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  orgUnit       OrgUnit?         @relation(fields: [orgUnitId], references: [id])

  sessions          ActiveSession[]
  userRoles         UserRole[]
  createdProspects  Prospect[]       @relation("CreatedProspects")
  ownedProspects    Prospect[]       @relation("OwnedProspects")
  createdProjects   Project[]        @relation("CreatedProjects")
  ownedProjects     Project[]        @relation("OwnedProjects")
  projectMembers    ProjectMember[]
  timelineEvents    ProjectTimelineEvent[]
  rksReviewQs       RksReviewQuestion[]
  rksReviewNs       RksReviewNote[]
  prospectReviewQuestions ProspectReviewQuestion[] @relation("ProspectReviewQuestionCreator")
  prospectReviewNotes     ProspectReviewNote[]     @relation("ProspectReviewNoteCreator")
  lphsReviewedBy    LphsDepartmentReview[]    @relation("LphsReviewedBy")
  lphsPmApprovedBy  LphsSios[]                @relation("LphsPmApproved")
  lphsMgmtApprovedBy LphsSios[]               @relation("LphsMgmtApproved")
  lphsFinalApproved LphsSios[]                @relation("LphsFinalApproved")
  lphsTargetedRevisions LphsTargetedRevision[]
  priceSubmissions  PriceSubmission[]
  tenderResults     TenderResult[]
  approvals         Approval[]                 @relation("ApprovalAssignee")
  approvalDecisions Approval[]                 @relation("ApprovalDecider")
  approvalReassignPrevious    ApprovalReassignment[] @relation("ApprovalReassignPrevious")
  approvalReassignNew         ApprovalReassignment[] @relation("ApprovalReassignNew")
  approvalReassignBy          ApprovalReassignment[] @relation("ApprovalReassignBy")
  backupApproverDelegations_primary  BackupApproverDelegation[] @relation("BackupPrimary")
  backupApproverDelegations_backup   BackupApproverDelegation[] @relation("BackupSecondary")
  backupApproverDelegations_created  BackupApproverDelegation[] @relation("BackupCreator")
  documentsUploaded  Document[]
  notifications      Notification[]
  auditLogs          AuditLog[]
  aiRequestLogs      AiRequestLog[]
  tasksCreated       Task[]          @relation("TasksCreated")
  tasksCompleted     Task[]          @relation("TasksCompleted")
  chats              ChatMessage[]
  readReceipts       ChatMessageReadReceipt[] @relation("ChatMessageReadReceiptUser")
  kpiWeights         KpiWeight[]
  targets            Target[]
  integrationConfigs IntegrationConfiguration[]
  slaReminders       SlaReminderConfiguration[] @relation("UserSlaReminders")
  approvalRequests   ApprovalRequest[]    @relation("ApprovalRequestsCreated")
  procurementCreated Procurement[]        @relation("ProcurementCreated")
  procurementDelivered Procurement[]      @relation("ProcurementDelivered")
  procurementClosed   Procurement[]      @relation("ProcurementClosed")
  rfqs               Rfq[]
  suppliers          Supplier[]
  supplierEvals      SupplierEvaluation[] @relation("UserSupplierEvals")

  @@map("users")
}

model ActiveSession {
  id        String    @id @default(uuid()) @map("id")
  userId    String    @map("user_id")
  tokenJti  String    @unique @map("token_jti") @db.VarChar(255)
  ipAddress String    @map("ip_address") @db.VarChar(45)
  userAgent String?   @map("user_agent") @db.Text
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime  @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("active_sessions")
}

model Role {
  id            String   @id @default(uuid()) @map("id")
  name          String   @db.VarChar(100)
  description   String?  @db.Text
  isSystem      Boolean  @default(false) @map("is_system")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  rolePermissions RolePermission[]
  userRoles        UserRole[]
  workflowStages   WorkflowStage[] @relation("RoleWorkflowStages")
  approvals        Approval[]     @relation("RoleApprovals")
  slaReminders     SlaReminderConfiguration[]
  notificationRecipients NotificationTemplateRecipient[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @map("id")
  code        String   @unique @db.VarChar(150)
  name        String   @db.VarChar(200)
  module      String   @db.VarChar(100)
  description String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id          String       @id @default(uuid()) @map("id")
  roleId      String       @map("role_id")
  permissionId String      @map("permission_id")
  scopeType   ApprovalScopeType? @map("scope_type")
  scopeId     String?      @map("scope_id")
  stageId     String?      @map("stage_id")
  accessLevel AccessLevel  @default(write) @map("access_level")
  createdAt   DateTime     @default(now()) @map("created_at")

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId, scopeType, scopeId])
  @@map("role_permissions")
}

model UserRole {
  id        String           @id @default(uuid()) @map("id")
  userId    String           @map("user_id")
  roleId    String           @map("role_id")
  scopeType ApprovalScopeType @map("scope_type")
  scopeId   String?          @map("scope_id")
  assignedBy String?         @map("assigned_by")
  expiresAt DateTime?        @map("expires_at")
  createdAt DateTime         @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@map("user_roles")
}

model WorkflowStage {
  id                  String   @id @default(uuid()) @map("id")
  code                String   @unique @db.VarChar(100)
  name                String   @db.VarChar(200)
  module              String   @db.VarChar(50)
  sequence            Float    @map("sequence")
  ownerDepartmentCode String   @map("owner_department_code") @db.VarChar(50)
  prevDepartmentCode  String?  @map("prev_department_code") @db.VarChar(50)
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  slaConfig SlaConfiguration?
  approvals Approval[]
  roleId    String?   @map("role_id")
  role      Role?     @relation("RoleWorkflowStages", fields: [roleId], references: [id])

  @@map("workflow_stages")
}

model ProjectMember {
  id           String   @id @default(uuid()) @map("id")
  projectId    String   @map("project_id")
  userId       String   @map("user_id")
  roleId       String   @map("role_id")
  departmentId String   @map("department_id")
  assignedBy   String   @map("assigned_by")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@map("project_members")
}

model ProjectDepartment {
  id           String   @id @default(uuid()) @map("id")
  projectId    String   @map("project_id")
  departmentId String   @map("department_id")
  createdAt    DateTime @default(now()) @map("created_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, departmentId])
  @@map("project_departments")
}

// ── MASTER DATA ──────────────────────────────────────────────────────────────

model Customer {
  id            String       @id @default(uuid()) @map("id")
  name          String       @unique @db.VarChar(255)
  code          String       @unique @db.VarChar(50)
  type          CustomerType
  city          String       @db.VarChar(100)
  npwp          String?      @db.VarChar(50)
  picName       String?      @map("pic_name") @db.VarChar(255)
  picPosition   String?      @map("pic_position") @db.VarChar(255)
  picPhone      String?      @map("pic_phone") @db.VarChar(50)
  picEmail      String?      @map("pic_email") @db.VarChar(255)
  address       String?      @db.Text
  province      String?      @db.VarChar(100)
  industryId    String?      @map("industry_id")
  providerExisting String?   @map("provider_existing") @db.VarChar(255)
  isNew         Boolean?     @default(false) @map("is_new")
  needsVerification Boolean? @default(false) @map("needs_verification")
  verifiedAt    DateTime?    @map("verified_at")
  verifiedBy    String?      @map("verified_by")
  isActive      Boolean      @default(true) @map("is_active")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")
  deletedAt     DateTime?    @map("deleted_at")

  prospects Prospect[]
  projects  Project[]

  @@map("customers")
}

model Industry {
  id        String   @id @default(uuid()) @map("id")
  name      String   @db.VarChar(200)
  code      String   @unique @db.VarChar(50)
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("industries")
}

model ProjectCategory {
  id               String   @id @default(uuid()) @map("id")
  name             String   @unique @db.VarChar(200)
  code             String   @unique @db.VarChar(50)
  description      String?  @db.Text
  requiresLphs     Boolean  @default(true) @map("requires_lphs")
  requiresRks      Boolean  @default(true) @map("requires_rks")
  defaultWorkflowType String @default("tender") @map("default_workflow_type") @db.VarChar(50)
  colorHex         String?  @map("color_hex") @db.VarChar(7)
  sortOrder        Int      @default(0) @map("sort_order")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  prospects Prospect[]
  projects  Project[]

  @@map("project_categories")
}

model ProjectStatusDefinition {
  id          String   @id @default(uuid()) @map("id")
  code        String   @unique @db.VarChar(50)
  label       String   @db.VarChar(100)
  description String?  @db.Text
  colorHex    String   @map("color_hex") @db.VarChar(7)
  textColorHex String  @map("text_color_hex") @db.VarChar(7)
  sortOrder   Int      @map("sort_order")
  isSystem    Boolean  @default(false) @map("is_system")
  isTerminal  Boolean  @default(false) @map("is_terminal")
  applicableTo String  @default("both") @map("applicable_to") @db.VarChar(20)
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  projects Project[]

  @@map("project_status_definitions")
}

model Competitor {
  id            String      @id @default(uuid()) @map("id")
  name          String      @unique @db.VarChar(200)
  code          String?     @db.VarChar(50)
  minPrice      Decimal?      @map("min_price") @db.Decimal(18, 2)
  maxPrice      Decimal?      @map("max_price") @db.Decimal(18, 2)
  industryId    String?     @map("industry_id")
  bidangUsaha   String?     @map("bidang_usaha") @db.VarChar(200)
  website       String?     @db.VarChar(255)
  advantages    String?     @db.Text
  description   String?     @db.Text
  notes         String?     @db.Text
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")
  deletedAt     DateTime?   @map("deleted_at")

  projectCompetitors ProjectCompetitor[]

  @@map("competitors")
}

model QuestionType {
  id              String         @id @default(uuid()) @map("id")
  name            String         @db.VarChar(100)
  code            QuestionTypeCode @unique
  description     String?        @db.Text
  hasOptions      Boolean        @default(false) @map("has_options")
  validationConfig String?       @map("validation_config") @db.Text
  isSystem        Boolean        @default(false) @map("is_system")
  isActive        Boolean        @default(true) @map("is_active")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  questions Question[]

  @@map("question_types")
}

model Question {
  id            String         @id @default(uuid()) @map("id")
  questionText  String         @map("question_text") @db.Text
  questionTypeId String        @map("question_type_id")
  context       QuestionContext
  category      String?        @db.VarChar(100)
  isRequired    Boolean        @default(false) @map("is_required")
  sortOrder     Int            @default(0) @map("sort_order")
  placeholderText String?      @map("placeholder_text") @db.Text
  helpText      String?        @map("help_text") @db.Text
  isActive      Boolean        @default(true) @map("is_active")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  deletedAt     DateTime?      @map("deleted_at")

  questionType         QuestionType       @relation(fields: [questionTypeId], references: [id])
  questionOptions      QuestionOption[]
  prospectAnswers      ProspectAnswer[]

  @@map("questions")
}

model QuestionOption {
  id          String   @id @default(uuid()) @map("id")
  questionId  String   @map("question_id")
  optionLabel String   @map("option_label") @db.VarChar(200)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  question            Question              @relation(fields: [questionId], references: [id], onDelete: Cascade)
  prospectAnswers     ProspectAnswer[]      @relation("QuestionOptionAnswers")
  prospectAnswerOpts  ProspectAnswerOption[]

  @@map("question_options")
}

model Period {
  id        String     @id @default(uuid()) @map("id")
  name      String     @db.VarChar(100)
  code      String     @unique @db.VarChar(50)
  type      PeriodType
  year      Int
  startDate DateTime   @map("start_date") @db.Date
  endDate   DateTime   @map("end_date") @db.Date
  isActive  Boolean    @default(true) @map("is_active")
  isLocked  Boolean    @default(false) @map("is_locked")
  notes     String?    @db.Text
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  targets Target[]

  @@map("periods")
}

model Holiday {
  id        String      @id @default(uuid()) @map("id")
  name      String      @db.VarChar(200)
  date      DateTime    @db.Date
  type      HolidayType
  year      Int
  isActive  Boolean     @default(true) @map("is_active")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  @@unique([date, type])
  @@map("holidays")
}

model LossReason {
  id          String            @id @default(uuid()) @map("id")
  name        String            @db.VarChar(200)
  code        String            @unique @db.VarChar(50)
  category    LossReasonCategory
  description String?           @db.Text
  sortOrder   Int               @default(0) @map("sort_order")
  isActive    Boolean           @default(true) @map("is_active")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")

  tenderResults TenderResult[]

  @@map("loss_reasons")
}

model DocumentType {
  id                String   @id @default(uuid()) @map("id")
  name              String   @db.VarChar(200)
  code              String   @unique @db.VarChar(50)
  description       String?  @db.Text
  allowedExtensions String?  @map("allowed_extensions") @db.Text
  maxSizeMb         Int?     @map("max_size_mb")
  isRequiredAtStage String?  @map("is_required_at_stage") @db.Text
  applicableTo      String   @default("both") @map("applicable_to") @db.VarChar(20)
  sortOrder         Int      @default(0) @map("sort_order")
  isSystem          Boolean  @default(false) @map("is_system")
  isActive          Boolean  @default(true) @map("is_active")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  documents Document[]
  uploadPolicies UploadPolicyConfiguration[]

  @@map("document_types")
}

// ── PROSPECT MANAGEMENT ──────────────────────────────────────────────────────

model Prospect {
  id                String          @id @default(uuid()) @map("id")
  name              String          @db.VarChar(255)
  client            String          @db.VarChar(255)
  customerId        String?         @map("customer_id")
  customerType      ProspectCustomerType? @map("customer_type")
  status            ProspectStatus  @default(Potensial)
  prospectType      String?         @map("prospect_type") @db.VarChar(50)
  potensiUnit       Int             @default(0) @map("potensi_unit")
  estimatedValue    Decimal?          @map("estimated_value") @db.Decimal(18, 2)
  description       String?         @db.Text
  branch            String?         @db.VarChar(100)
  branchId          String?         @map("branch_id")
  categoryId        String?         @map("category_id")
  industryId        String?         @map("industry_id")
  providerExisting  String?         @map("provider_existing") @db.VarChar(255)
  projectType       String?         @map("project_type") @db.VarChar(100)
  isConverted       Boolean         @default(false) @map("is_converted")
  convertedToProjectId String?      @unique @map("converted_to_project_id")
  createdByUserId   String?         @map("created_by_user_id")
  departmentId      String?         @map("department_id")
  currentStageId    String?         @map("current_stage_id")
  ownerUserId       String?         @map("owner_user_id")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  deletedAt         DateTime?       @map("deleted_at")

  customer          Customer?       @relation(fields: [customerId], references: [id])
  branchRel         OrgUnit?        @relation("BranchProspects", fields: [branchId], references: [id])
  category          ProjectCategory? @relation(fields: [categoryId], references: [id])
  createdBy         User?           @relation("CreatedProspects", fields: [createdByUserId], references: [id])
  ownerUser         User?           @relation("OwnedProspects", fields: [ownerUserId], references: [id])
  project           Project?        @relation("ProspectToProject", fields: [convertedToProjectId], references: [id])
  sourceProjects    Project[]       @relation("ProjectToProspect")

  answers            ProspectAnswer[]
  reviewQuestions    ProspectReviewQuestion[]
  reviewNotes        ProspectReviewNote[]
  timelineEvents     ProspectTimelineEvent[]

  @@map("prospects")
}

