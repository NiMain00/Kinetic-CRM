  unitReadyDate       DateTime?         @map("unit_ready_date")
  unitShippedDate     DateTime?         @map("unit_shipped_date")
  unitReceivedDate    DateTime?         @map("unit_received_date")
  actualEndDate       DateTime?         @map("actual_end_date")
  deliveryNote        String?           @map("delivery_note")
