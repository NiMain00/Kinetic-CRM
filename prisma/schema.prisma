  @@map("lphs_department_reviews")
}

model LphsTargetedRevision {
  id              String   @id @default(uuid()) @map("id")
  lphsSiosId      String   @map("lphs_sios_id")
  revisionNumber  Int      @map("revision_number")
  initiatedBy     String   @map("initiated_by")
  initiatedRole   String   @map("initiated_role")
  note            String? 
  createdAt       DateTime @default(now()) @map("created_at")

  lphsSios    LphsSios                        @relation(fields: [lphsSiosId], references: [id], onDelete: Cascade)
  initiator   User                            @relation(fields: [initiatedBy], references: [id])
  departments LphsTargetedRevisionDepartment[]

  @@map("lphs_targeted_revisions")
}

model LphsTargetedRevisionDepartment {
  id                       String   @id @default(uuid()) @map("id")
  lphsTargetedRevisionId   String   @map("lphs_targeted_revision_id")
  departmentId             String   @map("department_id")
  createdAt                DateTime @default(now()) @map("created_at")

  revision   LphsTargetedRevision @relation(fields: [lphsTargetedRevisionId], references: [id], onDelete: Cascade)
  department OrgUnit              @relation(fields: [departmentId], references: [id])

  @@unique([lphsTargetedRevisionId, departmentId])
  @@map("lphs_targeted_revision_departments")
}

