  reviewRound  Int      @map("review_round")
  questionText String   @map("question_text")
  answerText   String?  @map("answer_text")
  createdBy    String   @map("created_by")
  answeredAt   DateTime? @map("answered_at")
  createdAt    DateTime @default(now()) @map("created_at")

  rks     Rks  @relation(fields: [rksId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [createdBy], references: [id])

  @@map("rks_review_questions")
}

model RksReviewNote {
  id          String   @id @default(uuid()) @map("id")
  rksId       String   @map("rks_id")
  reviewRound Int      @map("review_round")
  noteText    String   @map("note_text")
  createdBy   String   @map("created_by")
  createdAt   DateTime @default(now()) @map("created_at")

  rks     Rks  @relation(fields: [rksId], references: [id], onDelete: Cascade)
  creator User @relation(fields: [createdBy], references: [id])

  @@map("rks_review_notes")
}

// ── LPHS/SIOS MODULE ─────────────────────────────────────────────────────────

model LphsSios {
  id                   String            @id @default(uuid()) @map("id")
  projectId            String            @unique @map("project_id")
  status               LphsStatus        @default(draft)
  lphsFileName         String?           @map("lphs_file_name")
  lphsFileSize         String?           @map("lphs_file_size")
  lphsExternalUrl      String?           @map("lphs_external_url")
  siosFileName         String?           @map("sios_file_name")
  siosFileSize         String?           @map("sios_file_size")
  selectedDepartments  String?           @map("selected_departments")
  departmentsLocked    Boolean           @default(false) @map("departments_locked")
  pmApprovalStatus     LphsApprovalStatus @default(reviewing) @map("pm_approval_status")
  pmApprovedAt         DateTime?         @map("pm_approved_at")
  pmApprovedBy         String?           @map("pm_approved_by")
  mgmtApprovalStatus   LphsApprovalStatus @default(reviewing) @map("mgmt_approval_status")
  mgmtApprovedAt       DateTime?         @map("mgmt_approved_at")
  mgmtApprovedBy       String?           @map("mgmt_approved_by")
  finalApprovalStatus  LphsApprovalStatus @default(pending_pm) @map("final_approval_status")
  finalApprovedAt      DateTime?         @map("final_approved_at")
  finalApprovedBy      String?           @map("final_approved_by")
  overallStatus        String            @default("draft") @map("overall_status")
