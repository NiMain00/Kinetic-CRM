# ===== APPLICATION =====
APP_ENV=development
APP_KEY=
APP_URL=http://localhost
APP_VERSION=1.0.0

# ===== NGINX =====
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ===== DATABASE =====
DB_ROOT_PASSWORD=rootpass
DB_DATABASE=kinetic_crm
DB_USERNAME=kinetic_user
DB_PASSWORD=secret

# ===== REDIS =====
REDIS_PASSWORD=redispass

# ===== JWT =====
JWT_SECRET=change-this-to-random-64-char-string
JWT_EXPIRY_HOURS=8

# ===== SESSION =====
SESSION_WARN_MINUTES=25

# ===== STORAGE =====
STORAGE_HOST_PATH=./storage
STORAGE_MAX_UPLOAD_MB=25

# ===== AI PROVIDER =====
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-pro
AI_EMBEDDING_MODEL=text-embedding-004
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.3
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3
AI_RATE_LIMIT_RPM=60
AI_COST_LIMIT_USD_PER_DAY=10.0
AI_ENABLED=true

# ===== EMAIL (FASE 2) =====
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=KINETIC CRM
SMTP_ENCRYPTION=tls

# ===== VITE (FRONTEND) =====
VITE_API_BASE_URL=http://localhost:4000
VITE_APP_VERSION=1.0.0

# ===== LOGGING =====
LOG_LEVEL=debug
LOG_CHANNEL=stderr
