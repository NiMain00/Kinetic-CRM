generator client {
  provider        = "prisma-client-js"
  binaryTargets   = ["native", "linux-musl"]
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ============================================================
// DOMAIN: ORGANIZATION & ACCESS
// ============================================================

model Company {
  id                String   @id @default(uuid()) @db.Char(36)
  name              String   @unique @db.VarChar(200)
  legalEntityNumber String?  @db.VarChar(100)
  logoDocumentId    String?  @db.Char(36)
  address           String?  @db.Text
  isActive          Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  deletedAt         DateTime?
}

model Division {
  id          String   @id @default(uuid()) @db.Char(36)
  companyId   String   @db.Char(36)
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(10)
  headUserId  String?  @db.Char(36)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

model Department {
  id                  String   @id @default(uuid()) @db.Char(36)
  divisionId          String?  @db.Char(36)
  parentDepartmentId  String?  @db.Char(36)
  name                String   @db.VarChar(200)
  code                String   @unique @db.VarChar(10)
  headUserId          String?  @db.Char(36)
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  deletedAt           DateTime?
}

model Branch {
  id          String   @id @default(uuid()) @db.Char(36)
  divisionId  String   @db.Char(36)
  name        String   @db.VarChar(200)
  code        String   @unique @db.VarChar(20)
  city        String   @db.VarChar(100)
  address     String?  @db.Text
  picUserId   String?  @db.Char(36)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  deletedAt   DateTime?
}

// ============================================================
// DOMAIN: ACCESS CONTROL
// ============================================================

model Role {
  id              String   @id @default(uuid()) @db.Char(36)
  code            String   @unique @db.VarChar(50)
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  isSystemDefault Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  users User[]
}

model Permission {
  id       String @id @default(uuid()) @db.Char(36)
  code     String @unique @db.VarChar(150)
  resource String @db.VarChar(100)
  action   String @db.VarChar(50)
  label    String @db.VarChar(200)
}

model RolePermission {
  id           String   @id @default(uuid()) @db.Char(36)
  roleId       String   @db.Char(36)
  permissionId String   @db.Char(36)
  createdAt    DateTime @default(now())

  @@unique([roleId, permissionId])
}

// ============================================================
// DOMAIN: AUTH
// ============================================================

model User {
  id                 String   @id @default(uuid()) @db.Char(36)
  name               String   @db.VarChar(150)
  username           String   @unique @db.VarChar(50)
  email              String   @unique @db.VarChar(150)
  passwordHash       String   @db.VarChar(255)
  roleId             String   @db.Char(36)
  branchId           String?  @db.Char(36)
  departmentId       String?  @db.Char(36)
  isActive           Boolean  @default(true)
  isLocked           Boolean  @default(false)
  lockedUntil        DateTime?
  failedLoginCount   Int      @default(0)
  lastLoginIp        String?  @db.VarChar(45)
  lastLoginAt        DateTime?
  mustChangePassword Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  deletedAt          DateTime?

  Role     Role             @relation(fields: [roleId], references: [id])
  sessions ActiveSession[]
}

model ActiveSession {
  id                String    @id @default(uuid()) @db.Char(36)
  userId            String    @db.Char(36)
  jti               String    @db.VarChar(255)
  refreshTokenHash  String    @unique @db.VarChar(255)
  ipAddress         String    @db.VarChar(45)
  userAgent         String?   @db.Text
  expiresAt         DateTime
  revokedAt         DateTime?
  createdAt         DateTime  @default(now())

  User User @relation(fields: [userId], references: [id])
}

model Position {
  id             String   @id @default(uuid()) @db.Char(36)
  name           String   @unique @db.VarChar(150)
  approvalLevel  Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model UserPosition {
  id         String   @id @default(uuid()) @db.Char(36)
  userId     String   @db.Char(36)
  positionId String   @db.Char(36)
  isBackup   Boolean  @default(false)
  validFrom  DateTime? @db.Date
  validUntil DateTime? @db.Date
  createdAt  DateTime @default(now())
}

// ============================================================
// DOMAIN: MASTER DATA
// ============================================================

model Customer {
  id         String   @id @default(uuid()) @db.Char(36)
  name       String   @unique @db.VarChar(200)
  code       String   @unique @db.VarChar(10)
  type       String   @db.VarChar(20)
  picContact String?  @db.VarChar(150)
  email      String?  @db.VarChar(150)
  phone      String?  @db.VarChar(30)
  address    String?  @db.Text
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  deletedAt  DateTime?
}

model ProjectCategory {
  id           String   @id @default(uuid()) @db.Char(36)
  name         String   @unique @db.VarChar(150)
  requiresLphs Boolean  @default(true)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProjectStatusDefinition {
  id           String   @id @default(uuid()) @db.Char(36)
  code         String   @unique @db.VarChar(50)
  label        String   @db.VarChar(100)
  color        String   @db.VarChar(7)
  displayOrder Int
  isTerminal   Boolean  @default(false)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ApprovalLevelDefinition {
  id          String  @id @default(uuid()) @db.Char(36)
  level       Int     @unique
  label       String  @db.VarChar(100)
  description String? @db.Text
}

model DocumentTypeDefinition {
  id              String  @id @default(uuid()) @db.Char(36)
  code            String  @unique @db.VarChar(50)
  label           String  @db.VarChar(100)
  appliesToStage  String? @db.VarChar(100)
  isActive        Boolean @default(true)
}

model Competitor {
  id            String   @id @default(uuid()) @db.Char(36)
  name          String   @unique @db.VarChar(200)
  shortCode     String?  @db.VarChar(20)
  businessField String?  @db.VarChar(150)
  description   String?  @db.Text
  status        String   @default("active") @db.VarChar(20)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
}

model QuestionType {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique @db.VarChar(50)
  label     String   @db.VarChar(100)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuestionTypeOption {
  id              String @id @default(uuid()) @db.Char(36)
  questionTypeId  String @db.Char(36)
  optionLabel     String @db.VarChar(200)
  displayOrder    Int    @default(0)
}

model Question {
  id             String   @id @default(uuid()) @db.Char(36)
  text           String   @db.Text
  questionTypeId String   @db.Char(36)
  context        String   @db.VarChar(20)
  categoryLabel  String?  @db.VarChar(150)
  isRequired     Boolean  @default(false)
  displayOrder   Int      @default(0)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?
}

model QuestionOption {
  id           String @id @default(uuid()) @db.Char(36)
  questionId   String @db.Char(36)
  optionLabel  String @db.VarChar(200)
  displayOrder Int    @default(0)
}

model PeriodDefinition {
  id        String   @id @default(uuid()) @db.Char(36)
  name      String   @db.VarChar(100)
  startDate DateTime @db.Date
  endDate   DateTime @db.Date
  isClosed  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Holiday {
  id                String   @id @default(uuid()) @db.Char(36)
  date              DateTime @unique @db.Date
  description       String   @db.VarChar(200)
  isRecurringAnnually Boolean @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model LossReason {
  id        String   @id @default(uuid()) @db.Char(36)
  code      String   @unique @db.VarChar(50)
  label     String   @db.VarChar(150)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============================================================
// DOMAIN: PROSPECT MANAGEMENT
// ============================================================

model Prospect {
  id                    String    @id @default(uuid()) @db.Char(36)
  name                  String    @db.VarChar(200)
  customerId            String    @db.Char(36)
  branchId              String    @db.Char(36)
  categoryId            String    @db.Char(36)
  description           String?   @db.Text
  estimatedValue        Decimal?  @db.Decimal(18, 2)
  estimatedDate         DateTime? @db.Date
  status                String    @default("prospecting") @db.VarChar(30)
  convertedToProjectId  String?   @unique @db.Char(36)
  createdBy             String    @db.Char(36)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?
}

model ProspectAnswer {
  id              String   @id @default(uuid()) @db.Char(36)
  prospectId      String   @db.Char(36)
  questionId      String   @db.Char(36)
  answerText      String?  @db.Text
  answerOptionId  String?  @db.Char(36)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([prospectId, questionId])
}

model ProspectAnswerOption {
  id                 String @id @default(uuid()) @db.Char(36)
  prospectAnswerId   String @db.Char(36)
  questionOptionId   String @db.Char(36)

  @@unique([prospectAnswerId, questionOptionId])
}

model ProspectReviewQuestion {
  id            String    @id @default(uuid()) @db.Char(36)
  prospectId    String    @db.Char(36)
  reviewRound   Int
  questionText  String    @db.Text
  answerText    String?   @db.Text
  createdBy     String    @db.Char(36)
  answeredAt    DateTime?
  createdAt     DateTime  @default(now())
}

model ProspectReviewNote {
  id          String   @id @default(uuid()) @db.Char(36)
  prospectId  String   @db.Char(36)
  reviewRound Int
  noteText    String   @db.Text
  createdBy   String   @db.Char(36)
  createdAt   DateTime @default(now())
}

// ============================================================
// DOMAIN: PROJECT CORE
// ============================================================

model Project {
  id                  String    @id @default(uuid()) @db.Char(36)
  prospectId          String?   @unique @db.Char(36)
  name                String    @db.VarChar(200)
  projectType         String    @db.VarChar(20)
  customerId          String    @db.Char(36)
  branchId            String    @db.Char(36)
  categoryId          String    @db.Char(36)
  statusId            String    @db.Char(36)
  deadlineTender      DateTime? @db.Date
  tenderNumber        String?   @db.VarChar(100)
  tenderName          String?   @db.VarChar(200)
  cancelledAt         DateTime?
  cancellationReason  String?   @db.Text
  cancelledBy         String?   @db.Char(36)
  createdBy           String    @db.Char(36)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  deletedAt           DateTime?

  @@unique([customerId, tenderNumber])
}

model ProjectTimelineEvent {
  id          String   @id @default(uuid()) @db.Char(36)
  projectId   String   @db.Char(36)
  eventType   String   @db.VarChar(100)
  actorId     String?  @db.Char(36)
  description String   @db.Text
  metadata    Json?
  occurredAt  DateTime @default(now())
}

// ============================================================
// DOMAIN: RKS MODULE
// ============================================================

model Rks {
  id             String    @id @default(uuid()) @db.Char(36)
  projectId      String    @unique @db.Char(36)
  content        String    @db.Text
  status         String    @default("draft") @db.VarChar(30)
  revisionNumber Int       @default(1)
  submittedAt    DateTime?
  approvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model RksReviewQuestion {
  id           String    @id @default(uuid()) @db.Char(36)
  rksId        String    @db.Char(36)
  reviewRound  Int
  questionText String    @db.Text
  answerText   String?   @db.Text
  createdBy    String    @db.Char(36)
  answeredAt   DateTime?
  createdAt    DateTime  @default(now())
}

model RksReviewNote {
  id          String   @id @default(uuid()) @db.Char(36)
  rksId       String   @db.Char(36)
  reviewRound Int
  noteText    String   @db.Text
  createdBy   String   @db.Char(36)
  createdAt   DateTime @default(now())
}

// ============================================================
// DOMAIN: LPHS/SIOS MODULE
// ============================================================

model LphsSios {
  id                   String    @id @default(uuid()) @db.Char(36)
  projectId            String    @unique @db.Char(36)
  status               String    @default("draft") @db.VarChar(30)
  linkLphsExternal     String?   @db.Text
  pmApprovalStatus     String    @default("pending") @db.VarChar(30)
  pmApprovedAt         DateTime?
  pmApprovedBy         String?   @db.Char(36)
  finalApprovalStatus  String    @default("pending") @db.VarChar(30)
  finalApprovedAt      DateTime?
  finalApprovedBy      String?   @db.Char(36)
  revisionNumber       Int       @default(1)
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model LphsDepartmentReview {
  id              String    @id @default(uuid()) @db.Char(36)
  lphsSiosId      String    @db.Char(36)
  departmentId    String    @db.Char(36)
  approvalStatus  String    @default("reviewing") @db.VarChar(30)
  comment         String?   @db.Text
  reviewedBy      String?   @db.Char(36)
  reviewedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([lphsSiosId, departmentId])
}

model LphsTargetedRevision {
  id              String   @id @default(uuid()) @db.Char(36)
  lphsSiosId      String   @db.Char(36)
  revisionNumber  Int
  initiatedBy     String   @db.Char(36)
  initiatedRole   String   @db.VarChar(20)
  note            String?  @db.Text
  createdAt       DateTime @default(now())
}

model LphsTargetedRevisionDepartment {
  id                        String @id @default(uuid()) @db.Char(36)
  lphsTargetedRevisionId    String @db.Char(36)
  departmentId              String @db.Char(36)

  @@unique([lphsTargetedRevisionId, departmentId])
}

// ============================================================
// DOMAIN: HARGA & KOMPETITOR
// ============================================================

model PriceSubmission {
  id               String    @id @default(uuid()) @db.Char(36)
  projectId        String    @unique @db.Char(36)
  ourPrice         Decimal   @db.Decimal(18, 2)
  marginPercentage Decimal?  @db.Decimal(5, 2)
  note             String?   @db.Text
  referenceLink    String?   @db.Text
  submittedAt      DateTime  @default(now())
  submittedBy      String    @db.Char(36)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model ProjectCompetitor {
  id               String   @id @default(uuid()) @db.Char(36)
  projectId        String   @db.Char(36)
  competitorId     String   @db.Char(36)
  competitorPrice  Decimal? @db.Decimal(18, 2)
  advantageNote    String?  @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([projectId, competitorId])
}

// ============================================================
// DOMAIN: PEMENANG & DELIVERY
// ============================================================

model TenderResult {
  id             String    @id @default(uuid()) @db.Char(36)
  projectId      String    @unique @db.Char(36)
  result         String    @db.VarChar(10)
  finalPrice     Decimal?  @db.Decimal(18, 2)
  lossReasonId   String?   @db.Char(36)
  lossReasonNote String?   @db.Text
  decidedAt      DateTime  @default(now())
  decidedBy      String    @db.Char(36)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model DeliveryTarget {
  id          String    @id @default(uuid()) @db.Char(36)
  projectId   String    @unique @db.Char(36)
  startDate   DateTime  @db.Date
  endDate     DateTime  @db.Date
  picName     String    @db.VarChar(150)
  notes       String?   @db.Text
  status      String    @default("scheduled") @db.VarChar(20)
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

// ============================================================
// DOMAIN: APPROVAL & WORKFLOW ENGINE
// ============================================================

model ApprovalWorkflowStage {
  id              String   @id @default(uuid()) @db.Char(36)
  stageCode       String   @unique @db.VarChar(100)
  label           String   @db.VarChar(150)
  approverRoleId  String   @db.Char(36)
  displayOrder    Int
  isParallel      Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Approval {
  id                      String   @id @default(uuid()) @db.Char(36)
  resourceType            String   @db.VarChar(30)
  resourceId              String   @db.Char(36)
  stageId                 String   @db.Char(36)
  assignedToUserId        String?  @db.Char(36)
  assignedToRoleId        String?  @db.Char(36)
  assignedToDepartmentId  String?  @db.Char(36)
  status                  String   @default("pending") @db.VarChar(20)
  decisionComment         String?  @db.Text
  decidedBy               String?  @db.Char(36)
  decidedAt               DateTime?
  slaDeadline             DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

model ApprovalReassignment {
  id                          String   @id @default(uuid()) @db.Char(36)
  approvalId                  String   @db.Char(36)
  previousAssigneeUserId      String?  @db.Char(36)
  newAssigneeUserId           String   @db.Char(36)
  reason                      String   @db.Text
  reassignedBy                String   @db.Char(36)
  reassignedAt                DateTime @default(now())
}

model BackupApproverDelegation {
  id             String   @id @default(uuid()) @db.Char(36)
  positionId     String   @db.Char(36)
  primaryUserId  String   @db.Char(36)
  backupUserId   String   @db.Char(36)
  validFrom      DateTime @db.Date
  validUntil     DateTime @db.Date
  createdBy      String   @db.Char(36)
  createdAt      DateTime @default(now())
}

// ============================================================
// DOMAIN: DOCUMENT MANAGEMENT
// ============================================================

model Document {
  id               String    @id @default(uuid()) @db.Char(36)
  documentTypeId   String    @db.Char(36)
  resourceType     String    @db.VarChar(30)
  resourceId       String    @db.Char(36)
  departmentId     String?   @db.Char(36)
  fileName         String    @db.VarChar(255)
  fileSizeBytes    BigInt
  mimeType         String    @db.VarChar(150)
  storagePath      String    @db.Text
  versionNumber    Int       @default(1)
  isLatestVersion  Boolean   @default(true)
  uploadedBy       String    @db.Char(36)
  uploadedAt       DateTime  @default(now())
  deletedAt        DateTime?
}

// ============================================================
// DOMAIN: TARGET & KPI
// ============================================================

model KpiDefinition {
  id                 String   @id @default(uuid()) @db.Char(36)
  code               String   @unique @db.VarChar(50)
  name               String   @db.VarChar(150)
  formulaDescription String   @db.Text
  unit               String   @db.VarChar(20)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model KpiWeight {
  id                String   @id @default(uuid()) @db.Char(36)
  kpiDefinitionId   String   @db.Char(36)
  weightPercentage  Decimal  @db.Decimal(5, 2)
  effectiveFrom     DateTime @db.Date
  effectiveUntil    DateTime? @db.Date
  createdBy         String   @db.Char(36)
  createdAt         DateTime @default(now())
}

model Target {
  id                String   @id @default(uuid()) @db.Char(36)
  kpiDefinitionId   String   @db.Char(36)
  scopeType         String   @db.VarChar(20)
  scopeId           String   @db.Char(36)
  periodId          String   @db.Char(36)
  targetValue       Decimal  @db.Decimal(18, 2)
  versionNumber     Int      @default(1)
  isCurrentVersion  Boolean  @default(true)
  createdBy         String   @db.Char(36)
  createdAt         DateTime @default(now())
}

model TargetProgressSnapshot {
  id                  String   @id @default(uuid()) @db.Char(36)
  targetId            String   @db.Char(36)
  snapshotDate        DateTime @db.Date
  actualValue         Decimal  @db.Decimal(18, 2)
  percentageAchieved  Decimal  @db.Decimal(6, 2)
  trafficLightStatus  String   @db.VarChar(10)
  createdAt           DateTime @default(now())

  @@unique([targetId, snapshotDate])
}

// ============================================================
// DOMAIN: NOTIFICATION
// ============================================================

model NotificationTemplate {
  id            String   @id @default(uuid()) @db.Char(36)
  eventCode     String   @unique @db.VarChar(100)
  templateText  String   @db.Text
  channel       String   @default("in_app") @db.VarChar(20)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NotificationTemplateRecipient {
  id                          String @id @default(uuid()) @db.Char(36)
  notificationTemplateId      String @db.Char(36)
  recipientRoleId             String? @db.Char(36)
  recipientDepartmentId       String? @db.Char(36)
}

model Notification {
  id                      String   @id @default(uuid()) @db.Char(36)
  notificationTemplateId  String   @db.Char(36)
  recipientUserId         String   @db.Char(36)
  resourceType            String?  @db.VarChar(50)
  resourceId              String?  @db.Char(36)
  message                 String   @db.Text
  isRead                  Boolean  @default(false)
  readAt                  DateTime?
  createdAt               DateTime @default(now())
}

// ============================================================
// DOMAIN: AUDIT
// ============================================================

model AuditLog {
  id               String   @id @default(uuid()) @db.Char(36)
  actorId          String?  @db.Char(36)
  actorRoleSnapshot String  @db.VarChar(50)
  action           String   @db.VarChar(150)
  resourceType     String?  @db.VarChar(50)
  resourceId       String?  @db.Char(36)
  branchIdSnapshot String?  @db.Char(36)
  ipAddress        String   @db.VarChar(45)
  userAgent        String?  @db.Text
  payloadBefore    Json?
  payloadAfter     Json?
  metadata         Json?
  result           String   @db.VarChar(20)
  errorCode        String?  @db.VarChar(100)
  createdAt        DateTime @default(now())
}

// ============================================================
// DOMAIN: CONFIGURATION & AI
// ============================================================

model SlaConfiguration {
  id                  String   @id @default(uuid()) @db.Char(36)
  stageId             String   @unique @db.Char(36)
  slaWorkingDays      Int
  isEnforcementActive Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model SlaReminderConfiguration {
  id                   String @id @default(uuid()) @db.Char(36)
  slaConfigurationId   String @db.Char(36)
  reminderDaysBefore   Int
  escalationRoleId     String? @db.Char(36)
}

model UploadPolicyConfiguration {
  id              String   @id @default(uuid()) @db.Char(36)
  documentTypeId  String   @unique @db.Char(36)
  maxSizeMb       Int
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model UploadPolicyMimeType {
  id                            String @id @default(uuid()) @db.Char(36)
  uploadPolicyConfigurationId   String @db.Char(36)
  mimeType                      String @db.VarChar(150)

  @@unique([uploadPolicyConfigurationId, mimeType])
}

model IntegrationConfiguration {
  id              String   @id @default(uuid()) @db.Char(36)
  key             String   @unique @db.VarChar(100)
  valueEncrypted  String   @db.Text
  isSecret        Boolean  @default(false)
  updatedBy       String   @db.Char(36)
  updatedAt       DateTime @updatedAt
}

model AiRequestLog {
  id            String   @id @default(uuid()) @db.Char(36)
  requestedBy   String   @db.Char(36)
  featureCode   String   @db.VarChar(50)
  resourceType  String?  @db.VarChar(50)
  resourceId    String?  @db.Char(36)
  provider      String   @db.VarChar(50)
  model         String   @db.VarChar(100)
  status        String   @db.VarChar(20)
  latencyMs     Int?
  errorCode     String?  @db.VarChar(100)
  createdAt     DateTime @default(now())
}
