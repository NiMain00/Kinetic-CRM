# Backend environment variables (used directly when running outside Docker)

NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
DATABASE_URL="mysql://kinetic_user:secret@localhost:3306/kinetic_crm"
JWT_SECRET=change-this-to-random-64-char-string
JWT_EXPIRY_HOURS=8

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redispass

# Storage
STORAGE_ROOT=./uploads
STORAGE_MAX_UPLOAD_MB=25

# AI Provider
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_MODEL=gemini-2.5-pro
AI_EMBEDDING_MODEL=text-embedding-004
AI_MAX_TOKENS=2048
AI_TEMPERATURE=0.3
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=3
AI_RATE_LIMIT_RPM=60
AI_COST_LIMIT_USD_PER_DAY=10.0
AI_ENABLED=true

# SMTP (Fase 2)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=KINETIC CRM
SMTP_ENCRYPTION=tls

# Logging
LOG_LEVEL=debug

# Session
SESSION_WARN_MINUTES=25
